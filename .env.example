# EcoPulse Environment Variables
# Copy this file to .env.local and fill in values.
# The app runs fully in demo/rule-based mode if these are absent.

# Optional: Groq API for AI-generated personalized insight summaries
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Optional: App URL (used in weekly report share links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
